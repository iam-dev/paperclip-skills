{
  "name": "@iam-dev/paperclip-skills",
  "version": "0.3.2",
  "description": "Adversarial brainstorm skills and agent assets for Paperclip AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "belief-engine": "dist/cli/belief-engine.js"
  },
  "files": [
    "dist",
    "skills",
    "agents",
    "scripts",
    "workspaces"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "node --test dist/**/*.test.js",
    "test:e2e": "npx playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:headed": "npx playwright test --config tests/e2e/playwright.config.ts --headed",
    "install-skills": "bash scripts/install.sh",
    "install-skills:dry-run": "bash scripts/install.sh --dry-run"
  },
  "keywords": [
    "paperclip",
    "skills",
    "brainstorm",
    "adversarial-debate",
    "ai-agents",
    "decision-making"
  ],
  "author": "iam-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iam-dev/paperclip-skills.git"
  },
  "dependencies": {
    "mnemebrain": "^0.1.0-alpha.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0"
  }
}
